# versions.env — single source of truth for all version-pinned values in this image.
#
# Each KEY corresponds to a named ARG of the same name in the Dockerfile. To
# upgrade, edit the values here (or let scripts/sync-versions.sh rewrite them
# from an upstream ref) — do NOT hardcode versions in the Dockerfile.
#
# The "upstream:" annotation records the matching ARG name in
# vllm-project/vllm docker/Dockerfile.rocm_base|rocm, so sync-versions.sh can
# map upstream pins onto these keys.

# --- base / platform -------------------------------------------------------
BASE_IMAGE=debian:bookworm-20260112
ROCM_VERSION=7.0                 # apt repo channel (repo.radeon.com/.../${ROCM_VERSION})
ROCM_PATH_VERSION=7.0.0          # on-disk path: /opt/rocm-${ROCM_PATH_VERSION}
PYTORCH_ROCM_ARCH=gfx90a;gfx942  # GPU arch targets for torch/fa/mori/vllm builds

# --- python / torch --------------------------------------------------------
TORCH_SPEC=torch==2.10.0+rocm7.0           # upstream: PYTORCH_BRANCH (we install a wheel, not a build)
TORCH_INDEX_URL=https://download.pytorch.org/whl/rocm7.0

# --- component refs (built from source into wheels) ------------------------
MORI_BRANCH=2d02c6a9             # upstream: MORI_BRANCH
MORI_GPU_TARGETS=gfx90a;gfx942
FA_BRANCH=0e60e394               # upstream: FA_BRANCH
FA_GPU_ARCHS=gfx90a;gfx942
AITER_BRANCH=6af8b687            # upstream: AITER_BRANCH
AITER_GPU_ARCHS=gfx942           # gfx90a unsupported by aiter (P88226)
VLLM_REF=6c0064571               # upstream: vLLM checkout (docker/Dockerfile.rocm)
VLLM_GPU_ARCHS=gfx90a;gfx942
