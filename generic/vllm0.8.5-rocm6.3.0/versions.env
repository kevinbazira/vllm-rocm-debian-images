# versions.env — single source of truth for all version-pinned values in this image.
#
# Each KEY corresponds to a named ARG of the same name in the Dockerfile. To
# upgrade, edit the values here (or let scripts/sync-versions.sh rewrite them
# from an upstream ref) — do NOT hardcode versions in the Dockerfile.
#
# NOTE: this is the older stack — gfx90a only, stable torch, FlashAttention +
# vLLM only (no MoRi, no aiter). Schema intentionally differs from vllm0.14.

# --- base / platform -------------------------------------------------------
BASE_IMAGE=debian:bookworm-20250428
ROCM_VERSION=6.3.1               # rocm apt channel
AMDGPU_VERSION=6.3.1             # amdgpu apt channel (tracked separately upstream)
PYTORCH_ROCM_ARCH=gfx90a         # MI210 only on this build

# --- python / torch --------------------------------------------------------
TORCH_SPEC=torch==2.8.0+rocm6.3
TORCH_INDEX_URL=https://download.pytorch.org/whl/rocm6.3

# --- component refs (built from source into wheels) ------------------------
FA_BRANCH=1a7f4dfa               # upstream: FA_BRANCH
FA_GPU_ARCHS=gfx90a
VLLM_REPO=https://github.com/vllm-project/vllm.git
VLLM_BRANCH=main
VLLM_REF=c53e073                 # upstream: vLLM checkout
